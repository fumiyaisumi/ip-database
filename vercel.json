{
  "rewrites": [
    { "source": "/", "destination": "/ip-database.html" },
    { "source": "/tasks", "destination": "/tasks.html" },
    { "source": "/roadmap", "destination": "/roadmap.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
